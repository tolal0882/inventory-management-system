# ─── Database ────────────────────────────────────────────
# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://postgres:password@localhost:5432/inventory_db"

# ─── JWT Auth ────────────────────────────────────────────
# Use a long random string (min 32 chars) — never share this
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
JWT_EXPIRES_IN="7d"

# ─── App ─────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── CORS ────────────────────────────────────────────────
# Your React frontend URL
FRONTEND_URL="http://localhost:5173"

# ─── Seed credentials ────────────────────────────────────
# Used only by: npx ts-node prisma/seed.ts
SEED_ADMIN_EMAIL="admin@example.com"
SEED_ADMIN_PASSWORD="Admin@12345"
SEED_ADMIN_NAME="Administrator"

# ─── Brevo Email (for OTP password reset) ─────────────────
# Get an API key at: https://app.brevo.com/settings/keys/api
# BREVO_SENDER_EMAIL must be a verified sender in your Brevo account
BREVO_API_KEY=your-brevo-api-key
BREVO_SENDER_EMAIL=your-verified-sender@example.com
