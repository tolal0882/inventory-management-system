generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  Admin
  Inventory_Staff
  Warehouse_Manager
  Auditor
}

enum UserStatus {
  Active
  Inactive
  Pending
  PendingDeletion
}

enum TransactionType {
  IN
  OUT
  TRANSFER
  SHRINKAGE
}

enum TransactionStatus {
  Pending
  Approved
  Rejected
}

enum ShrinkageReason {
  Damaged
  Expired
  Lost
  Theft
  Other
}

enum PurchaseOrderStatus {
  Draft
  Sent
  Received
  Cancelled
}

enum InvoiceStatus {
  Draft
  Pending
  Paid
  Cancelled
}

enum ActivityAction {
  Login
  Logout
}

model User {
  id           String     @id @default(uuid())
  name         String
  email        String     @unique
  password     String
  role         UserRole   @default(Inventory_Staff)
  status       UserStatus @default(Active)
  workplace    String?
  department   String?
  phone        String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  lowStockAlerts       Boolean  @default(true)
  orderNotifications   Boolean  @default(true)
  pushNotifications    Boolean  @default(false)
  twoFactorEnabled     Boolean  @default(false)
  sessionTimeoutMinutes Int?    @default(30)
  ipWhitelist          String?
  auditLoggingEnabled  Boolean  @default(true)

  transactions     StockTransaction[]
  purchaseOrders   PurchaseOrder[]
  invoices         Invoice[]
  activityLogs     UserActivityLog[]
}

model Product {
  id              String    @id @default(uuid())
  sku             String    @unique
  name            String
  category        String
  unit            String
  costPrice       Float
  stockQuantity   Int       @default(0)
  minStock        Int       @default(0)
  status          UserStatus @default(Active)
  expirationDate  DateTime?
  hasExpiration   Boolean   @default(false)
  supplierId      String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  supplier         Supplier? @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  transactions     StockTransaction[]
  purchaseOrders   PurchaseOrder[]
  invoiceItems     InvoiceItem[]
}

model Supplier {
  id          String   @id @default(uuid())
  name        String
  contact     String
  email       String
  address     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  suppliedProducts Product[]
  purchaseOrders PurchaseOrder[]
  invoices       Invoice[]
}

model StockTransaction {
  id              String            @id @default(uuid())
  productId       String
  productName     String
  type            TransactionType
  quantity        Int
  date            DateTime          @default(now())
  userId          String
  userName        String
  note            String?
  status          TransactionStatus @default(Pending)
  warehouse       String
  fromWarehouse   String?
  toWarehouse     String?
  shrinkageReason ShrinkageReason?
  purchaseOrderId String?           @unique
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  product       Product        @relation(fields: [productId], references: [id])
  user          User           @relation(fields: [userId], references: [id])
  purchaseOrder PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id])
}

model PurchaseOrder {
  id               String              @id @default(uuid())
  orderNumber      String              @unique
  productId        String
  productName      String
  supplierId       String
  supplierName     String
  quantity         Int
  unitPrice        Float
  totalAmount      Float
  orderDate        DateTime            @default(now())
  expectedDelivery DateTime
  status           PurchaseOrderStatus @default(Draft)
  createdById      String
  notes            String?
  autoGenerated    Boolean             @default(false)
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  product         Product           @relation(fields: [productId], references: [id])
  supplier        Supplier          @relation(fields: [supplierId], references: [id])
  createdBy       User              @relation(fields: [createdById], references: [id])
  stockTransaction StockTransaction?
  invoice         Invoice?
}

model Invoice {
  id              String        @id @default(uuid())
  invoiceNumber   String        @unique
  supplierId      String
  supplierName    String
  invoiceDate     DateTime
  dueDate         DateTime
  subtotal        Float
  tax             Float
  totalAmount     Float
  status          InvoiceStatus @default(Draft)
  notes           String?
  createdById     String
  purchaseOrderId String?       @unique
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  supplier      Supplier       @relation(fields: [supplierId], references: [id])
  createdBy     User           @relation(fields: [createdById], references: [id])
  purchaseOrder PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id])
  items         InvoiceItem[]
}

model InvoiceItem {
  id          String  @id @default(uuid())
  invoiceId   String
  productId   String
  productName String
  quantity    Int
  unitPrice   Float
  totalPrice  Float

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])
}

model UserActivityLog {
  id        String         @id @default(uuid())
  userId    String
  userName  String
  action    ActivityAction
  timestamp DateTime       @default(now())
  ipAddress String?
  device    String?
  location  String?

  user User @relation(fields: [userId], references: [id])
}

model OtpRecord {
  id        String   @id @default(uuid())
  email     String
  code      String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([email])
}

// Single-row system-wide config, always read/written at id "system"
model SystemSettings {
  id                       String   @id @default("system")
  lowStockThresholdPercent Int      @default(20)
  defaultCategory          String   @default("Other")
  updatedAt                DateTime @updatedAt
}
